generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(cuid())
  username        String?          @unique
  firstName       String           @map("first_name")
  lastName        String?          @map("last_name")
  bio             String?          @map("bio")
  avatars         String[]
  birthDate       DateTime?        @map("birth_date")
  lastSeenAt      DateTime?        @map("last_seen_at")
  privacySettings PrivacySettings?
  chatFolders     ChatFolder[]
  searchHistory   SearchHistory[]
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@map("users")
}

model ChatFolder {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  includedChatIds String[] @default([]) @map("included_chat_ids")
  excludedChatIds String[] @default([]) @map("excluded_chat_ids")
  includedTypes   String[] @default([]) @map("included_types")
  excludedTypes   String[] @default([]) @map("excluded_types")
  inviteLink      String?  @map("invite_link")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([userId, sortOrder])
  @@map("chat_folders")
}

model PrivacySettings {
  id           String      @id @default(cuid())
  userId       String      @unique @map("user_id")
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone        PrivacyType @default(PRIVACY_TYPE_UNSPECIFIED)
  lastSeenTime PrivacyType @default(PRIVACY_TYPE_UNSPECIFIED) @map("last_seen_time")
  photo        PrivacyType @default(PRIVACY_TYPE_UNSPECIFIED)
  bio          PrivacyType @default(PRIVACY_TYPE_UNSPECIFIED)
  call         PrivacyType @default(PRIVACY_TYPE_UNSPECIFIED)
  reply        PrivacyType @default(PRIVACY_TYPE_UNSPECIFIED)
  invite       PrivacyType @default(PRIVACY_TYPE_UNSPECIFIED)
  mediaMessage PrivacyType @default(PRIVACY_TYPE_UNSPECIFIED) @map("media_message")
  message      PrivacyType @default(PRIVACY_TYPE_UNSPECIFIED)
  birthDate    PrivacyType @default(PRIVACY_TYPE_UNSPECIFIED) @map("birth_date")

  @@map("privacy_settings")
}

model SearchHistory {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query           String
  normalizedQuery String   @map("normalized_query")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([userId, normalizedQuery])
  @@index([userId, updatedAt])
  @@map("search_history")
}

enum PrivacyType {
  PRIVACY_TYPE_UNSPECIFIED
  ALL
  CONTACTS
  NOBODY
}
